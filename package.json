{
  "name": "lattice-ts",
  "version": "1.0.0",
  "description": "Production-grade TypeScript backend template powered by Clean Architecture, SOLID, and strict layer isolation",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "generate:module": "ts-node scripts/create-module.ts"
  },
  "keywords": [
    "lattice",
    "clean-architecture",
    "solid",
    "backend-template",
    "repository-pattern",
    "orchestrator-pattern",
    "unit-of-work"
  ],
  "author": "shregar1",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.19.43",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "reflect-metadata": "^0.2.2",
    "zod": "^4.4.3"
  }
}
